#!/usr/bin/env bash
# Author: NAZY-OS
# License: MIT
# Name: tty-dmesgd
# Version: 1.0.6
#
# This script repeatedly runs dmesg in follow mode and redirects its output
# to /dev/tty12. It requires root permissions. If not run as root, it exits.

set -euo pipefail

TTY_DEV="/dev/tty12"
# Use -T for human-readable timestamps; there is no --human flag in dmesg.
DMS_CMD="dmesg --human -T"

if [[ "${EUID}" -ne 0 ]]; then
  echo "Error: run as root." >&2
  exit 1
fi

## MAIN

echo "DMESG INFOS TO: ${TTY_DEV}"

### PRELOOP
   sh -c "${DMS_CMD} --follow 2>&1 | tee -a ${TTY_DEV}" &> /var/log/dmesg.log.0
### LOOP


while true; do
  sh -c "${DMS_CMD} --follow-new 2>&1 | tee -a ${TTY_DEV}" &>> /var/log/dmesg.log.0
  sleep 1
done
